/* avada-post.css - estilos adaptados do tema avada original */
:root {
  /* variáveis padrão para garantir que o layout renderize quando faltar as injeções do tema */
  --site_width: 1200px;
  --primary_color: #a5002c; /* cor vermelho lafam */
  --link_color: #181818;
  --link_hover_color: #a5002c;
  --body_typography-color: #555555;
  --body_typography-font-size: 15px;
  --h3_typography-color: #333333;
  --h3_typography-font-size: 24px;
  --h3_typography-font-family: 'Roboto', sans-serif;
  --h3_typography-font-weight: 400;
  --h3_typography-line-height: 1.4;
  --h3_typography-letter-spacing: 0;
  --h3_typography-text-transform: none;
  --title_border_color: #e2e2e2;
  --title_margin-top: 30px;
  --title_margin-bottom: 20px;
  --title_margin-left: 0;
  --title_margin-right: 0;
  --full_width_bg_color: transparent;
  --full_width_border_color: #e2e2e2;
  --hundredp_padding: 30px;
  --hundredp_padding-hundred_percent_negative_margin: -30px;
  --col_margin-top: 0px;
  --col_margin_bottom: 20px;
  --col_spacing: 4%;
  --container_padding_default_top: 0px;
  --container_padding_default_bottom: 0px;
  --container_padding_default_left: 0px;
  --container_padding_default_right: 0px;
}

